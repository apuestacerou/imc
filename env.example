# Copia este archivo a .env en la raíz del proyecto Expo (mismo nivel que package.json).
# Reinicia el bundler tras cambiar variables.

# URL del API (carpeta server/). Opcional en dev: la app infiere el host desde Expo
# (misma PC que Metro) o usa 10.0.2.2 en emulador Android.
# Descomenta y ajusta si usas túnel o el auto‑host no te sirve:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
