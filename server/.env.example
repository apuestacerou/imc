# Plantilla: en este repo suele existir server/.env ya configurado para el equipo.
# Si clonas y no ves .env, copia este archivo a .env y rellena los valores.

# Sin channel_binding (en Node + @neondatabase/serverless puede colgar con channel_binding=require)
DATABASE_URL=postgresql://usuario:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

PORT=3000

# Opcional. Por defecto 0.0.0.0 (todas las interfaces). Solo usa 127.0.0.1 si no quieres LAN.
# LISTEN_HOST=0.0.0.0
